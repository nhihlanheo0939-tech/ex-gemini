{
  "manifest_version": 3,
  "name": "Gemini Prompt Opener",
  "version": "1.2",
  "description": "Chọn Topic, mở prompt Gemini và đóng hết tab đã mở khi cần.",
  "permissions": ["tabs", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon128.png",
    "default_title": "Gemini Prompt Opener"
  },
  "icons": {
    "128": "icon128.png"
  }
}
